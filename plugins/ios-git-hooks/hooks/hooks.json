{
  "description": "Git safety hooks for iOS projects — blocks commits to main and runs pre-commit quality checks on Swift files",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/guard-main-branch.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/pre-commit-quality.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
